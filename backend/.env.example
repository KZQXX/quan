# Environment Configuration — copy to .env and fill in real values
#
# Application
APP_NAME="Pet Tracker"
APP_VERSION="0.1.0"
DEBUG=false
PORT=8000

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL="sqlite+aiosqlite:///./pet_tracker.db"
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/pet_tracker"
DB_POOL_SIZE=10
DB_ECHO=false

# JWT Auth
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=60

# CORS — comma-separated origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Logging
LOG_LEVEL="INFO"
